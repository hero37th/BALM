<launch>
        <arg name="rviz" default="true" />

        <param name="voxel_size" type="double" value="2" />
        <param name="frame_num" type="int" value="20" />
        <param name="lidar_topic" type="string" value="/lslidar_point_cloud" />
        <node pkg="balm2" type="benchmark_lidar" name="benchmark_lidar" output="screen" />

        <group if="$(arg rviz)">
                <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find balm2)/rviz_cfg/back.rviz" />
        </group>

</launch>
